# Обязательный секрет для клиентов (16 байт hex)
MT_SECRET=0123456789abcdef0123456789abcdef

# Порт MTProto для клиентов
MT_PORT=1443

# Локальный порт статистики
MT_STATS_PORT=8888

# Кол-во воркеров mtproto-proxy
MT_WORKERS=1

# Тег из @MTProxybot (опционально)
MT_PROXY_TAG=

# Интервал автообновления proxy-multi.conf в секундах (86400 = 24ч)
MT_CONFIG_UPDATE_INTERVAL=86400

# Опционально: переопределение URL источников
PROXY_SECRET_URL=https://core.telegram.org/getProxySecret
PROXY_CONFIG_URL=https://core.telegram.org/getProxyConfig
